---
import BaseLayout from '@/components/BaseLayout.astro';
import TestCard from '@/components/TestCard.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import { getTestsInCategory, getTestsByCategory } from '@/lib/medical-tests/queries';
import { categoryMeta, type CategoryKey } from '@/i18n/categories';
import { buildCategoryURL, buildURL, buildPillarURL } from '@/i18n/routes';
import { collectionPage, itemList, breadcrumbList } from '@/lib/seo/json-ld';
import { t } from '@/i18n/ui';

export function getStaticPaths() {
  return (Object.keys(categoryMeta) as CategoryKey[]).map((key) => ({
    params: { category: categoryMeta[key].en.slug },
    props: { key },
  }));
}

const { key } = Astro.props as { key: CategoryKey };
const lang = 'en' as const;
const meta = categoryMeta[key];
const label = meta[lang].label;
const illustration = 'illustration' in meta ? meta.illustration : undefined;

const site = (import.meta.env.PUBLIC_SITE_URL || 'https://symptomatik.com').replace(/\/$/, '');
const canonical = site + buildCategoryURL(lang, key);

const descriptionText = `Guide to ${label} tests — what they measure, normal ranges, and how to interpret your results.`;

const tests = await getTestsInCategory(lang, key);

const byCategory = await getTestsByCategory(lang);
const siblingKeys = (Object.keys(categoryMeta) as CategoryKey[])
  .filter((k) => k !== key && (byCategory.get(k)?.length ?? 0) > 0)
  .sort((a, b) => categoryMeta[a][lang].label.localeCompare(categoryMeta[b][lang].label))
  .slice(0, 3);

const alternates = [
  { hreflang: 'en', href: site + buildCategoryURL('en', key) },
  { hreflang: 'pl', href: site + buildCategoryURL('pl', key) },
  { hreflang: 'x-default', href: site + buildCategoryURL('en', key) },
];

const breadcrumbs = [
  { label: t(lang, 'breadcrumbs.home'), href: site + '/' },
  { label: t(lang, 'breadcrumbs.medicalTests'), href: site + buildPillarURL(lang, 'medical-tests') },
  { label },
];

const jsonLd = [
  collectionPage({
    url: canonical,
    title: label,
    description: descriptionText,
    inLanguage: lang,
  }),
  itemList(
    tests.map((entry, i) => ({
      position: i + 1,
      name: entry.data.title,
      url: site + buildURL({ lang, collection: 'medical-tests', slug: entry.data.slug }),
    }))
  ),
  breadcrumbList(breadcrumbs),
];
---
<BaseLayout
  title={`${label} — Medical Tests | Symptomatik`}
  description={descriptionText}
  canonical={canonical}
  alternates={alternates}
  locale={lang}
  jsonLd={jsonLd}
>
  <div class="max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <section class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <nav aria-label="Breadcrumb" class="text-xs text-neutral-500 mb-4">
          <a href="/" class="hover:underline">{t(lang, 'breadcrumbs.home')}</a>
          <span class="mx-2">/</span>
          <a href={buildPillarURL(lang, 'medical-tests')} class="hover:underline">{t(lang, 'breadcrumbs.medicalTests')}</a>
          <span class="mx-2">/</span>
          <span>{label}</span>
        </nav>
        <h1 class="font-serif text-5xl md:text-6xl font-semibold text-neutral-900 leading-tight">
          {label}
        </h1>
        <p class="mt-6 text-lg text-neutral-600 max-w-xl">
          {descriptionText}
        </p>
      </div>
      {illustration ? (
        <div class="hero-illustration">
          <img
            src={illustration}
            alt=""
            loading="eager"
            decoding="async"
            class="hero-illustration__img"
          />
        </div>
      ) : (
        <div class="hero-illustration" style={`background-color: ${meta.paletteAccent}33`}></div>
      )}
    </section>

    <section class="mt-16 md:mt-24">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {tests.map((entry) => (
          <TestCard
            href={buildURL({ lang, collection: 'medical-tests', slug: entry.data.slug })}
            title={entry.data.title}
            aiUseCase={entry.data.aiUseCase}
            categoryLabel={label}
            paletteAccent={meta.paletteAccent}
          />
        ))}
      </div>
    </section>

    {siblingKeys.length > 0 && (
      <section class="mt-16 md:mt-24">
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-neutral-900 mb-8">
          {t(lang, 'category.relatedHeading')}
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {siblingKeys.map((k) => {
            const sibMeta = categoryMeta[k];
            const sibTests = byCategory.get(k) ?? [];
            const sibIllustration = 'illustration' in sibMeta ? sibMeta.illustration : undefined;
            const baseProps = {
              href: buildCategoryURL(lang, k),
              label: sibMeta[lang].label,
              testCount: sibTests.length,
              illustrationBg: '#F5F0EC',
              paletteAccent: sibMeta.paletteAccent,
            };
            return sibIllustration
              ? <CategoryCard {...baseProps} illustration={sibIllustration} />
              : <CategoryCard {...baseProps} />;
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .hero-illustration {
    display: flex;
    justify-content: center;
    align-items: center;
    aspect-ratio: 1 / 1;
    max-width: 440px;
    width: 100%;
    margin-left: auto;
    background: #F5F0EC;
    border-radius: 50%;
    overflow: hidden;
  }

  .hero-illustration__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
