---
import PillarSearchIsland from './PillarSearch.tsx';
import '@/components/pillar-search.css';
import { t } from '@/i18n/ui';

interface Props { lang: 'en' | 'pl'; }
const { lang } = Astro.props;
---
<div class="my-6">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="pillar-search" class="pillar-search"></div>
  <PillarSearchIsland client:load lang={lang} placeholder={t(lang, 'search.placeholder')} />
</div>
