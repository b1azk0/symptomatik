---
interface Props {
  href: string;
  title: string;
  aiUseCase: string;
  categoryLabel: string;
  paletteAccent: string;
}

const { href, title, aiUseCase, categoryLabel, paletteAccent } = Astro.props;
---
<a
  href={href}
  class="test-card"
  data-palette-accent={paletteAccent}
>
  <div class="test-card__eyebrow" style={`color: ${paletteAccent}`}>
    {categoryLabel}
  </div>
  <div class="test-card__title">{title}</div>
  {aiUseCase && <div class="test-card__excerpt">{aiUseCase}</div>}
</a>

<style>
  .test-card {
    display: block;
    background: #FFFFFF;
    border: 1px solid #F0E0D0;
    border-radius: 8px;
    padding: 20px;
    text-decoration: none;
    transition: border-color 0.15s ease;
  }

  .test-card:hover {
    border-color: #D4BAC8;
  }

  .test-card__eyebrow {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .test-card__title {
    font-family: 'Geist', ui-sans-serif, system-ui, sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #2B2626;
    line-height: 1.3;
    margin-bottom: 4px;
  }

  .test-card__excerpt {
    font-family: 'Geist', ui-sans-serif, system-ui, sans-serif;
    font-size: 13px;
    color: #7A6A5E;
    line-height: 1.4;
  }
</style>
